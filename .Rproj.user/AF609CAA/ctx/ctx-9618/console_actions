        "+ ",
        "          transpose = TRUE) %>% ",
        "+ ",
        "      tb() %>% ",
        "+ ",
        "      rename(Estadistico = 1) %>% ",
        "+ ",
        "      mutate(",
        "+ ",
        "        Variable = v, ",
        "+ ",
        "        Response = label_cmp,",
        "+ ",
