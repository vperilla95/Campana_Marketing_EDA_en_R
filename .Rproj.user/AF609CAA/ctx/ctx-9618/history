print(paste0("inconsistencias MntTotal = MntWines + MntFruits + MntMeatProducts + MntFishProducts + MntSweetProducts --> ", porcentaje_inconsistentes_mnt,"%"))
data_temp <- datos_sin_inconsistencia_v1
categorias_productos <- c("MntGoldProds","MntRegularProds")
data_temp$suma_calculada_productos <- rowSums(data_temp[, categorias_productos], na.rm = TRUE) # na.rm = TRUE trata nan como 0
registros_inconsistentes_mnt <- data_temp[data_temp$MntTotal != data_temp$suma_calculada_productos, ]
cantidad_inconsistentes_mnt <- nrow(registros_inconsistentes_mnt)
porcentaje_inconsistentes_mnt <- round(
100 * cantidad_inconsistentes_mnt / nrow(data_temp), 2
)
